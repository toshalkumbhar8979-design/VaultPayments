# ══════════════════════════════════════════════
#  NexusPay Backend — Environment Configuration
#  Copy to .env and fill in all values
# ══════════════════════════════════════════════

# ── Server ────────────────────────────────────
NODE_ENV=production
PORT=5000
API_VERSION=v1

# ── Security (REQUIRED — generate strong random values) ───────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_PLUS_CHAR_RANDOM_STRING

# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_KEY

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_WEBHOOK_SECRET

# ── Database ──────────────────────────────────
# Path to SQLite file (Railway/Render: use /data/nexuspay.db for persistence)
DB_PATH=./data/nexuspay.db

# ── Email (SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# For Gmail: Settings → Security → App Passwords → Generate
SMTP_PASS=your-16-char-app-password
FROM_EMAIL=payments@yourdomain.com
FROM_NAME=NexusPay

# ── Frontend URL (for CORS) ───────────────────
# Your Cloudflare Pages / GitHub Pages URL
FRONTEND_URL=https://yourbrand.pages.dev

# ── Platform Settings ─────────────────────────
PLATFORM_NAME=NexusPay
GATEWAY_FEE_PERCENT=2.5
DEFAULT_CURRENCY=INR

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# ── Optional: UPI VPA for QR ─────────────────
# The UPI Virtual Payment Address used in QR codes
UPI_VPA=nexuspay@upi
