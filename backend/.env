# ══════════════════════════════════════════════
#  VaultPay Backend — Environment Configuration
#  Copy to .env and fill in all values
# ══════════════════════════════════════════════

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── Security (REQUIRED — generate strong random values) ───────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=be04a547a7ce8b66f492eb34b819c6e4aa529abe6542aec057d19a8650ad302e18dc75572830d6e4bceddf62e8dc29c9

# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=4f6609691c7fff54cde87fec1eb1e83d

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=77fcfe6615d4b20d2e653daaa1d4bae06159a02cf22fa95d5269c9c40d14e5c0

# ── Database ──────────────────────────────────
# Path to SQLite file (Railway/Render: use /data/vaultpay.db for persistence)
DB_PATH=./data/vaultpay.db

# ── Email (SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# For Gmail: Settings → Security → App Passwords → Generate
SMTP_PASS=your-16-char-app-password
FROM_EMAIL=payments@yourdomain.com
FROM_NAME=VaultPay

# ── Frontend URL (for CORS) ───────────────────
# Your Cloudflare Pages / GitHub Pages URL
FRONTEND_URL=https://yourbrand.pages.dev

# ── Platform Settings ─────────────────────────
PLATFORM_NAME=VaultPay
GATEWAY_FEE_PERCENT=2.5
DEFAULT_CURRENCY=INR

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# ── Optional: UPI VPA for QR ─────────────────
# The UPI Virtual Payment Address used in QR codes
UPI_VPA=vaultpay@upi
